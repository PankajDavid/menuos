PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/menuos

# JWT
JWT_SECRET=change_this_to_256_bit_random_secret
JWT_REFRESH_SECRET=change_this_too_another_256_bit_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379

# Platform super admin
PLATFORM_ADMIN_EMAIL=admin@menuos.app

# QR base URL
QR_BASE_URL=http://localhost:5173

# Payment mode: mock | razorpay | stripe
PAYMENT_MODE=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
